rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default catch-all rule
    match /{document=**} {
      allow read, write: if true;
    }

    // Registrations collection rules
    match /registrations/{id} {
      allow read, write: if true;
    }

    // Classrooms collection rules
    match /classrooms/{id} {
      allow read, write: if true;
    }

    // Lessons collection rules
    match /lessons/{id} {
      allow read, write: if true;
    }

    // Exams collection rules
    match /exams/{id} {
      allow read, write: if true;
    }

    // ExamSessions collection rules
    match /sessions/{id} {
      allow read, write: if true;
    }

    // Evaluations collection rules
    match /evaluations/{id} {
      allow read, write: if true;
    }

    // Admin settings rules
    match /admin_settings/{settingId} {
      allow read, write: if true;
    }
  }
}
